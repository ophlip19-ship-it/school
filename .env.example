# Frontend
VITE_MAPBOX_TOKEN=your_mapbox_public_token
# Local backend (default):
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
# Production example (Render):
# VITE_API_URL=https://scholrun-api.onrender.com/api
# VITE_SOCKET_URL=https://scholrun-api.onrender.com

# Backend
PORT=5000
JWT_SECRET=change-me
CLIENT_ORIGIN=http://localhost:3000
DEMO_PAYMENTS=true

# MongoDB (local, Atlas, or memory)
MONGODB_URI=mongodb://127.0.0.1:27017/schoolrun
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/schoolrun
# Force in-memory DB for local demo without MongoDB installed:
# USE_MEMORY_DB=true
# MONGODB_URI=memory

# Stripe (optional — leave empty to use demo card checkout)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
